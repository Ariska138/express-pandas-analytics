{
  "version": 2,
  "functions": {
    "src/index.js": {
      "runtime": "@vercel/node@4"
    },
    "api/**/*.py": {
      "runtime": "@vercel/python@4"
    }
  },
  "routes": [
    {
      "src": "/api/analisis(.*)",
      "dest": "api/analisis.py"
    },
    {
      "src": "/(.*)",
      "dest": "src/index.js"
    }
  ]
}
